{
  "name": "mcp-claude-code-browser-feedback",
  "version": "0.7.0",
  "description": "MCP server for collecting visual browser feedback and sending to Claude Code",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "browser-feedback-mcp": "./src/server.js"
  },
  "scripts": {
    "typecheck": "tsc",
    "start": "node --experimental-strip-types src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itk-dev/mcp-claude-code-browser-feedback.git"
  },
  "bugs": {
    "url": "https://github.com/itk-dev/mcp-claude-code-browser-feedback/issues"
  },
  "homepage": "https://github.com/itk-dev/mcp-claude-code-browser-feedback#readme",
  "author": "yepzdk",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "html2canvas": "^1.4.1",
    "ws": "^8.16.0"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "feedback",
    "browser",
    "annotation",
    "debugging",
    "model-context-protocol"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
